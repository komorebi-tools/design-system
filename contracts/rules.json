[
  {
    "id": "NO_EMOJI",
    "severity": "error",
    "description": "絵文字禁止。Material Icons を使う",
    "detector": "regex",
    "pattern": "[😀-🧿🌀-🗿☀-⟿🪀-🫿]",
    "alternative": "<span class=\"material-icons\">icon_name</span>"
  },
  {
    "id": "NO_TEXT_BLACK",
    "severity": "error",
    "description": "#000000 禁止。#333333 を使う",
    "detector": "regex",
    "pattern": "#000000|#000;|color:\\s*black[^-]",
    "alternative": "#333333 または var(--text)"
  },
  {
    "id": "NO_FULLWIDTH_SLASH",
    "severity": "warning",
    "description": "全角スラッシュ禁止。半角 + 前後スペース",
    "detector": "regex",
    "pattern": "／",
    "alternative": " / "
  },
  {
    "id": "NO_FULLWIDTH_PAREN",
    "severity": "warning",
    "description": "全角括弧禁止。半角 + スペース",
    "detector": "regex",
    "pattern": "[（）]",
    "alternative": " ( ) with spaces"
  },
  {
    "id": "NO_FULLWIDTH_COLON",
    "severity": "warning",
    "description": "全角コロン禁止。半角 + 前後スペース",
    "detector": "regex",
    "pattern": "：",
    "alternative": " : "
  },
  {
    "id": "NO_FULLWIDTH_NAKAGURO",
    "severity": "warning",
    "description": "全角中黒禁止。半角中黒を使う",
    "detector": "regex",
    "pattern": "・",
    "alternative": "\\u00B7 (half-width)"
  },
  {
    "id": "NO_BORDER_RADIUS_50",
    "severity": "warning",
    "description": "border-radius: 50% 禁止。6-8px で統一",
    "detector": "regex",
    "pattern": "border-radius:\\s*50%",
    "alternative": "border-radius: 6px or 8px"
  },
  {
    "id": "NO_LINE_HEIGHT_LOW",
    "severity": "warning",
    "description": "日本語本文に line-height 1.5 以下は禁止",
    "detector": "regex",
    "pattern": "line-height:\\s*(1\\.[0-4]|1\\.5)\\b",
    "alternative": "line-height: 1.6"
  },
  {
    "id": "NO_HARDCODED_PRIMARY",
    "severity": "warning",
    "description": "Primary カラー直書き禁止。CSS variable を使う",
    "detector": "regex",
    "pattern": "#6[Ee]87[Bb]6",
    "alternative": "var(--primary)"
  }
]
